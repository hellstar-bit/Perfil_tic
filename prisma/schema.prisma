generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Perfil {
  id          String   @id @default(cuid())
  slug        String   @unique
  nombre       String
  cargo        String
  departamento String @default("")
  municipio    String @default("")
  email        String
  telefono    String?
  foto        String?
  frase       String?
  disponible  Boolean  @default(true)
  modalidad   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  habilidades Habilidad[]
  proyectos   Proyecto[]
  formacion   Formacion[]
  experiencia Experiencia[]
}

model Habilidad {
  id       String @id @default(cuid())
  perfilId String
  nombre   String
  nivel    Int
  perfil   Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)
}

model Proyecto {
  id          String  @id @default(cuid())
  perfilId    String
  titulo      String
  descripcion String
  tag         String?
  enlace      String?
  imagen      String?
  perfil      Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)
}

model Formacion {
  id          String  @id @default(cuid())
  perfilId    String
  programa    String
  institucion String
  nivel       String
  anioInicio  String
  anioFin     String
  urlCert     String?
  perfil      Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)
}

model Experiencia {
  id          String @id @default(cuid())
  perfilId    String
  cargo       String
  empresa     String
  periodo     String
  descripcion String
  tipo        String
  perfil      Perfil @relation(fields: [perfilId], references: [id], onDelete: Cascade)
}
